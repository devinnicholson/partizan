{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Partizan Wave 69-R Gate C pre-result suite v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "suite_id", "phase", "registry_ref", "preregistration_ref", "gate_s_go_ref", "implementation", "temporal_boundary", "source_repositories", "seed_contract", "policy_contract", "target_count", "proposal_count_per_target", "targets", "freeze_boundary"],
  "properties": {
    "schema_version": {"const": "partizan.wave69r_gate_c_suite.v0.1"},
    "suite_id": {"type": "string", "pattern": "^suite-sha256:[0-9a-f]{64}$"},
    "phase": {"const": "pre_verification_freeze"},
    "registry_ref": {"type": "object", "additionalProperties": false, "required": ["path", "schema_version", "registry_id", "sha256"], "properties": {"path": {"$ref": "#/$defs/path"}, "schema_version": {"const": "partizan.wave69_target_registry.v0.1"}, "registry_id": {"type": "string", "pattern": "^registry-sha256:[0-9a-f]{64}$"}, "sha256": {"$ref": "#/$defs/sha256"}}},
    "preregistration_ref": {"type": "object", "additionalProperties": false, "required": ["path", "schema_version", "preregistration_id", "sha256"], "properties": {"path": {"$ref": "#/$defs/path"}, "schema_version": {"const": "text/markdown"}, "preregistration_id": {"type": "string", "pattern": "^prereg-sha256:[0-9a-f]{64}$"}, "sha256": {"$ref": "#/$defs/sha256"}}},
    "gate_s_go_ref": {"type": "object", "additionalProperties": false, "required": ["path", "schema_version", "evidence_id", "evidence_commit", "decision", "sha256"], "properties": {"path": {"$ref": "#/$defs/path"}, "schema_version": {"const": "partizan.wave69r_structural_supply_evidence.v0.1"}, "evidence_id": {"type": "string", "pattern": "^evidence-sha256:[0-9a-f]{64}$"}, "evidence_commit": {"$ref": "#/$defs/commit"}, "decision": {"const": "GO"}, "sha256": {"$ref": "#/$defs/sha256"}}},
    "implementation": {"type": "object", "additionalProperties": false, "required": ["implementation_id", "partizan_commit", "components"], "properties": {"implementation_id": {"type": "string", "pattern": "^implementation-sha256:[0-9a-f]{64}$"}, "partizan_commit": {"$ref": "#/$defs/commit"}, "components": {"type": "array", "minItems": 20, "maxItems": 20, "items": {"$ref": "#/$defs/file_ref"}}}},
    "temporal_boundary": {"type": "object", "additionalProperties": false, "required": ["implementation_commit", "implementation_parent", "gate_s_evidence_commit", "pre_result_parent_commit"], "properties": {"implementation_commit": {"$ref": "#/$defs/commit"}, "implementation_parent": {"const": "6ddd22af4adb7ff8f6f4c361a9132720a47e87b7"}, "gate_s_evidence_commit": {"$ref": "#/$defs/commit"}, "pre_result_parent_commit": {"$ref": "#/$defs/commit"}}},
    "source_repositories": {"$ref": "#/$defs/repositories"},
    "seed_contract": {"type": "object", "additionalProperties": false, "required": ["algorithm", "domain_hex", "target_id_encoding"], "properties": {"algorithm": {"const": "sha256_first_u64_big_endian_v1"}, "domain_hex": {"const": "70617274697a616e2f773639722f63616c6962726174696f6e2f763100"}, "target_id_encoding": {"const": "ascii"}}},
    "policy_contract": {"type": "object", "additionalProperties": false, "required": ["schema_version", "random_replicates", "random_seed_domain_hex", "permutation_algorithm", "heuristic_version"], "properties": {"schema_version": {"const": "partizan.wave69r_policy_orders.v0.1"}, "random_replicates": {"const": 1000}, "random_seed_domain_hex": {"const": "70617274697a616e2f773639722f72616e646f6d2f763100"}, "permutation_algorithm": {"const": "splitmix64_rejection_fisher_yates_v1"}, "heuristic_version": {"const": "partizan.fixed_structural_heuristic.v1"}}},
    "target_count": {"const": 6},
    "proposal_count_per_target": {"const": 1024},
    "targets": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"$ref": "#/$defs/target"}},
    "freeze_boundary": {"type": "object", "additionalProperties": false, "required": ["gate_s_go_required", "verifier_calls", "results_artifacts_present", "stage_b_material_present", "wave70_material_present", "policy_orders_frozen_before_verification"], "properties": {"gate_s_go_required": {"const": true}, "verifier_calls": {"const": 0}, "results_artifacts_present": {"const": false}, "stage_b_material_present": {"const": false}, "wave70_material_present": {"const": false}, "policy_orders_frozen_before_verification": {"const": true}}}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"},
    "file_ref": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"$ref": "#/$defs/path"}, "sha256": {"$ref": "#/$defs/sha256"}}},
    "repositories": {"type": "object", "additionalProperties": false, "required": ["partizan", "astralbase", "bitmesh", "thermograph"], "properties": {"partizan": {"$ref": "#/$defs/commit"}, "astralbase": {"const": "1434fca1fc04d97798ec1b820c56f52f8014ccc7"}, "bitmesh": {"const": "ade3417a007b9c8392d8a153abc4b3ed23edf0aa"}, "thermograph": {"const": "1d9b6b01c3921aca8c2a8fb13972fee8a4de5041"}}},
    "artifact": {"type": "object", "additionalProperties": false, "required": ["path", "schema_version", "sha256", "row_count"], "properties": {"path": {"$ref": "#/$defs/path"}, "schema_version": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "row_count": {"const": 1024}}},
    "id_ref": {"type": "object", "additionalProperties": false, "required": ["path", "schema_version", "sha256", "identifier"], "properties": {"path": {"$ref": "#/$defs/path"}, "schema_version": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "identifier": {"type": "string", "minLength": 1}}},
    "target": {"type": "object", "additionalProperties": false, "required": ["target_id", "family", "bin_index", "calibration_seed", "target_ref", "board_stream_ref", "construction_certificates_ref", "proposals_ref", "generation_receipt_ref", "pool_manifest_ref", "policy_orders_ref"], "properties": {"target_id": {"type": "string", "pattern": "^target-sha256:[0-9a-f]{64}$"}, "family": {"type": "string", "minLength": 1}, "bin_index": {"enum": [0, 3]}, "calibration_seed": {"type": "integer", "minimum": 0, "maximum": 18446744073709551615}, "target_ref": {"type": "object", "additionalProperties": false, "required": ["path", "schema_version", "sha256", "target_id"], "properties": {"path": {"$ref": "#/$defs/path"}, "schema_version": {"const": "partizan.discovery_target.v0.1"}, "sha256": {"$ref": "#/$defs/sha256"}, "target_id": {"type": "string", "pattern": "^target-sha256:[0-9a-f]{64}$"}}}, "board_stream_ref": {"$ref": "#/$defs/artifact"}, "construction_certificates_ref": {"$ref": "#/$defs/artifact"}, "proposals_ref": {"$ref": "#/$defs/artifact"}, "generation_receipt_ref": {"type": "object", "additionalProperties": false, "required": ["path", "schema_version", "sha256", "receipt_id"], "properties": {"path": {"$ref": "#/$defs/path"}, "schema_version": {"const": "partizan.candidate_generation_receipt.v0.2"}, "sha256": {"$ref": "#/$defs/sha256"}, "receipt_id": {"type": "string", "pattern": "^receipt-sha256:[0-9a-f]{64}$"}}}, "pool_manifest_ref": {"type": "object", "additionalProperties": false, "required": ["path", "schema_version", "sha256", "pool_id"], "properties": {"path": {"$ref": "#/$defs/path"}, "schema_version": {"const": "partizan.candidate_pool_manifest.v0.3"}, "sha256": {"$ref": "#/$defs/sha256"}, "pool_id": {"type": "string", "pattern": "^pool-sha256:[0-9a-f]{64}$"}}}, "policy_orders_ref": {"type": "object", "additionalProperties": false, "required": ["path", "schema_version", "sha256", "policy_orders_id"], "properties": {"path": {"$ref": "#/$defs/path"}, "schema_version": {"const": "partizan.wave69r_policy_orders.v0.1"}, "sha256": {"$ref": "#/$defs/sha256"}, "policy_orders_id": {"type": "string", "pattern": "^policy-orders-sha256:[0-9a-f]{64}$"}}}}}
  }
}
