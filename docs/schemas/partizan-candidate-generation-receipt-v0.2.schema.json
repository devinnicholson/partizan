{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Partizan candidate generation receipt v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "target_ref", "board_stream", "construction_catalog", "construction_certificates", "projection", "generator", "candidate_artifact", "executions", "source_repositories"],
  "properties": {
    "schema_version": {"const": "partizan.candidate_generation_receipt.v0.2"},
    "receipt_id": {"type": "string", "pattern": "^receipt-sha256:[0-9a-f]{64}$"},
    "target_ref": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "schema_version", "target_id", "sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/relative_path"},
        "schema_version": {"const": "partizan.discovery_target.v0.1"},
        "target_id": {"type": "string", "pattern": "^target-sha256:[0-9a-f]{64}$"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "board_stream": {
      "allOf": [
        {"$ref": "#/$defs/jsonl_ref"},
        {"type": "object", "properties": {"schema_version": {"const": "partizan.candidate_board_stream.v0.1"}}}
      ]
    },
    "construction_catalog": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "schema_version", "catalog_id", "sha256", "construction_contract"],
      "properties": {
        "path": {"$ref": "#/$defs/relative_path"},
        "schema_version": {"const": "partizan.dfile_two_component_constructive_catalog.v0.2"},
        "catalog_id": {"type": "string", "pattern": "^catalog-sha256:[0-9a-f]{64}$"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "construction_contract": {"const": "partizan.dfile_two_component_constructive_grammar.v0.2"}
      }
    },
    "construction_certificates": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "schema_version", "row_count", "sha256", "template_ids_sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/relative_path"},
        "schema_version": {"const": "partizan.structural_construction_certificate.v0.1"},
        "row_count": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "template_ids_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "projection": {
      "type": "object", "additionalProperties": false,
      "required": ["contract_id", "implementation_commit", "target_fields_consumed", "mapping"],
      "properties": {
        "contract_id": {"const": "partizan.target_free_board_to_candidate_proposal.v0.1"},
        "implementation_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "target_fields_consumed": {"const": ["/domain", "/search_limits/max_pool_size", "/target_id"]},
        "mapping": {
          "type": "object", "additionalProperties": false,
          "required": ["/schema_version", "/proposal_id", "/target_id", "/domain", "/candidate_key", "/ordinal", "/position", "/generator", "/proposal_features"],
          "properties": {
            "/schema_version": {"const": "constant:partizan.candidate_proposal.v0.1"},
            "/proposal_id": {"const": "canonical_identity:proposal_without_proposal_id"},
            "/target_id": {"const": "target:/target_id"},
            "/domain": {"const": "target:/domain"},
            "/candidate_key": {"const": "canonical_identity:target_domain_plus_board_position"},
            "/ordinal": {"const": "board:/ordinal"},
            "/position": {"const": "board:/position"},
            "/generator": {"const": "board:/generator"},
            "/proposal_features": {"const": "board:/proposal_features"}
          }
        }
      }
    },
    "generator": {"$ref": "#/$defs/generator"},
    "candidate_artifact": {
      "allOf": [
        {"$ref": "#/$defs/jsonl_ref"},
        {"type": "object", "properties": {"schema_version": {"const": "partizan.candidate_proposal.v0.1"}}}
      ]
    },
    "executions": {
      "type": "object", "additionalProperties": false,
      "required": ["mode", "run_count", "board_stream_raw_sha256", "construction_certificate_sha256", "projection_artifact_sha256", "byte_identical"],
      "properties": {
        "mode": {"const": "separate_python_processes_v1"},
        "run_count": {"const": 2},
        "board_stream_raw_sha256": {"$ref": "#/$defs/two_hashes"},
        "construction_certificate_sha256": {"$ref": "#/$defs/two_hashes"},
        "projection_artifact_sha256": {"$ref": "#/$defs/two_hashes"},
        "byte_identical": {"const": true}
      }
    },
    "source_repositories": {"$ref": "#/$defs/repositories"}
  },
  "$defs": {
    "relative_path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "jsonl_ref": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "schema_version", "row_count", "sha256"],
      "properties": {"path": {"$ref": "#/$defs/relative_path"}, "schema_version": {"type": "string", "minLength": 1}, "row_count": {"type": "integer", "minimum": 1}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "generator": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "version", "code_commit", "family", "operator", "config_sha256", "random_seed"],
      "properties": {
        "name": {"const": "partizan_candidate_pool_generator"},
        "version": {"type": "string", "minLength": 1},
        "code_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "family": {"type": "string", "minLength": 1},
        "operator": {"type": "string", "minLength": 1},
        "config_sha256": {"$ref": "#/$defs/sha256"},
        "random_seed": {"type": "integer", "minimum": 0}
      }
    },
    "two_hashes": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/sha256"}},
    "repositories": {
      "type": "object", "additionalProperties": false,
      "required": ["astralbase", "bitmesh", "thermograph", "partizan"],
      "properties": {"astralbase": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "bitmesh": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "thermograph": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "partizan": {"type": "string", "pattern": "^[0-9a-f]{40}$"}}
    }
  }
}
