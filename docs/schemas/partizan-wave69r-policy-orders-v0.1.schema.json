{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Partizan Wave 69-R pre-result policy orders v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_orders_id", "target_id", "pool_id", "proposal_artifact", "freeze_boundary", "random_policy", "heuristic_policy"],
  "properties": {
    "schema_version": {"const": "partizan.wave69r_policy_orders.v0.1"},
    "policy_orders_id": {"type": "string", "pattern": "^policy-orders-sha256:[0-9a-f]{64}$"},
    "target_id": {"type": "string", "pattern": "^target-sha256:[0-9a-f]{64}$"},
    "pool_id": {"type": "string", "pattern": "^pool-sha256:[0-9a-f]{64}$"},
    "proposal_artifact": {"type": "object", "additionalProperties": false, "required": ["schema_version", "sha256", "row_count"], "properties": {"schema_version": {"const": "partizan.candidate_proposal.v0.1"}, "sha256": {"$ref": "#/$defs/sha256"}, "row_count": {"const": 1024}}},
    "freeze_boundary": {"const": "before_any_verifier_result"},
    "random_policy": {"type": "object", "additionalProperties": false, "required": ["version", "replicate_count", "seed_derivation", "permutation_algorithm", "orders"], "properties": {"version": {"const": "partizan.random_permutation.v1"}, "replicate_count": {"const": 1000}, "seed_derivation": {"const": "first_u64_be_sha256(\"partizan/w69r/random/v1\\0\" || pool_id || \"\\0\" || ascii_decimal_replicate)"}, "permutation_algorithm": {"const": "splitmix64_rejection_fisher_yates_v1"}, "orders": {"type": "array", "minItems": 1000, "maxItems": 1000, "items": {"$ref": "#/$defs/order"}}}},
    "heuristic_policy": {"type": "object", "additionalProperties": false, "required": ["version", "formula", "features", "sort_direction", "tie_break", "order"], "properties": {"version": {"const": "partizan.fixed_structural_heuristic.v1"}, "formula": {"type": "string", "minLength": 1}, "features": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"type": "string", "minLength": 1}}, "sort_direction": {"const": "score_descending"}, "tie_break": {"const": "candidate_key_ascending"}, "order": {"$ref": "#/$defs/order"}}}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "order": {"type": "object", "additionalProperties": false, "required": ["order_id", "policy", "replicate", "seed", "ordered_proposal_ids_sha256", "proposal_count", "target_id", "pool_id"], "properties": {"order_id": {"type": "string", "pattern": "^policy-order-sha256:[0-9a-f]{64}$"}, "policy": {"enum": ["random", "fixed_heuristic"]}, "replicate": {"type": ["integer", "null"], "minimum": 0}, "seed": {"type": ["integer", "null"], "minimum": 0}, "ordered_proposal_ids_sha256": {"$ref": "#/$defs/sha256"}, "proposal_count": {"const": 1024}, "target_id": {"type": "string", "pattern": "^target-sha256:[0-9a-f]{64}$"}, "pool_id": {"type": "string", "pattern": "^pool-sha256:[0-9a-f]{64}$"}}}
  }
}
